# Application
APP_NAME=ai-generator
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DB_NAME=ai_generator
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PASS=
REDIS_PORT=6379

# Fal.ai
FAL_KEY=your-fal-api-key-here
FAL_KEY_FALLBACK=your-fallback-fal-api-key-here
FAL_WEBHOOK_BASE_URL=http://localhost:8000

# Payment webhook authentication (HMAC-SHA256 shared secret)
PAYMENT_WEBHOOK_SECRET=your-payment-webhook-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TOKENS_PER_DOLLAR=100

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BLOCK_SECONDS=60

# Webhook delivery
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_INTERVAL_SECONDS=15

# Circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=7

# Ngrok (for docker-compose.ngrok.yml)
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
